{
  "compilerOptions": {
    "target": "es2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": { "@/*": ["./client/src/*"] },
    "typeRoots": ["./client/node_modules/@types", "./node_modules/@types"],
    "types": ["react", "react-dom", "node"]
  },
  "include": [
    "client/src/**/*.ts",
    "client/src/**/*.tsx",
    "client/next-env.d.ts",
    "client/src/global.d.ts",
    "server/src/**/*.ts"
  ],
  "exclude": ["node_modules", "client/node_modules", "server/node_modules", "client/.next", "server/dist"]
}
